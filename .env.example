# Copy this file to `.env` in the repo root and fill in your values.
# `.env` is gitignored — safe for real keys. NEVER commit `.env` to GitHub.
#
# Quick setup:
#   cp .env.example .env   # then edit .env
#
# Pre-push checklist:
#   git status             # .env must NOT appear
#   git check-ignore -v .env   # should show .gitignore rule

DEEPSEEK_API_KEY=sk-your-key-here
DEEPSEEK_BASE_URL=https://api.deepseek.com
DEEPSEEK_MODEL=deepseek-v4-flash
DEEPSEEK_REASONING_EFFORT=
DEEPSEEK_THINKING_ENABLED=false

# ISMCTS value network (belief-augmented MLP trained via collect_value_data + train_value_mlp)
ISMCTS_VALUE_MLP_PATH=models/value_mlp.pt
# Optional PPO fallback if MLP missing
ISMCTS_RL_VALUE_MODEL=
# Gauntlet eval: false = Pikalytics species-usage weights; true = equal 1/N
GAUNTLET_EQUAL_WEIGHTS=false
